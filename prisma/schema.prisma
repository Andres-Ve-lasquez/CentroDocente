generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
  ASSISTANT
}

enum ClassStatus {
  PLANNED
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum ResourceType {
  GUIDE
  PPT
  WORKSHEET
  ASSESSMENT
  LINK
  VIDEO
  DOCUMENT
  SIMCE
  OBJECTIVE_BANK
}

enum SourceType {
  CANVAS
  ONEDRIVE
  LOCAL
  UPLOADED
  GENERATED
}

enum SyncStatus {
  OK
  PENDING
  ERROR
}

enum TagType {
  SKILL
  AXIS
  EVALUATION
  DIFFICULTY
  SIMCE
  CUSTOM
}

enum GeneratedItemType {
  OBJECTIVE
  ACTIVITY
  WORKSHEET
  QUESTION_SET
  SIMCE_SET
  IDEA
  RUBRIC
  EXIT_TICKET
}

enum CanvasItemType {
  COURSE
  MODULE
  ASSIGNMENT
  FILE
  PAGE
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  role               UserRole            @default(TEACHER)
  timezone           String              @default("America/Santiago")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  ownedWorkspaces    Workspace[]         @relation("WorkspaceOwner")
  memberships        WorkspaceMember[]
  createdClasses     ClassSession[]      @relation("ClassCreatedBy")
  createdResources   Resource[]          @relation("ResourceCreatedBy")
  generatedItems     GeneratedItem[]     @relation("GeneratedBy")
}

model Workspace {
  id           String            @id @default(cuid())
  name         String
  ownerUserId  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  owner        User              @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members      WorkspaceMember[]
  courses      Course[]
  resources    Resource[]
  tags         Tag[]
  objectives   CurriculumObjective[]
  curriculumUnits CurriculumUnit[]
  canvasItems CanvasExternalItem[]
  generations  GeneratedItem[]

  @@index([ownerUserId])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        UserRole  @default(TEACHER)
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Course {
  id                     String          @id @default(cuid())
  workspaceId            String
  name                   String
  level                  String
  subject                String
  schoolYear             Int
  color                  String?
  externalCanvasCourseId String?
  isActive               Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  workspace              Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  units                  Unit[]
  classes                ClassSession[]
  resources              Resource[]
  generatedItems         GeneratedItem[]
  canvasItems            CanvasExternalItem[]

  @@index([workspaceId, schoolYear])
  @@index([workspaceId, level, subject])
}

model Unit {
  id          String         @id @default(cuid())
  courseId    String
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  orderIndex  Int            @default(0)
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  classes     ClassSession[]
  resources   Resource[]

  @@index([courseId, orderIndex])
}

model ClassSession {
  id                    String                  @id @default(cuid())
  courseId              String
  unitId                String?
  title                 String
  classDate             DateTime
  startTime             String?
  endTime               String?
  objectiveText         String?
  skillsText            String?
  notes                 String?
  status                ClassStatus             @default(PLANNED)
  reusedFromClassId     String?
  createdById           String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  course                Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  unit                  Unit?                   @relation(fields: [unitId], references: [id], onDelete: SetNull)
  reusedFromClass       ClassSession?           @relation("ClassReuse", fields: [reusedFromClassId], references: [id], onDelete: SetNull)
  reusedByClasses       ClassSession[]          @relation("ClassReuse")
  createdBy             User?                   @relation("ClassCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  resources             Resource[]
  objectives            ClassSessionObjective[]
  generatedItems        GeneratedItem[]

  @@index([courseId, classDate])
  @@index([unitId])
  @@index([reusedFromClassId])
}

model Resource {
  id              String              @id @default(cuid())
  workspaceId     String
  courseId        String?
  unitId          String?
  classSessionId  String?
  title           String
  description     String?
  resourceType    ResourceType
  sourceType      SourceType
  mimeType        String?
  fileExtension   String?
  searchText      String?
  hash            String?
  isReusable      Boolean             @default(true)
  recommended     Boolean             @default(false)
  usedCount       Int                 @default(0)
  lastUsedAt      DateTime?
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  course          Course?             @relation(fields: [courseId], references: [id], onDelete: SetNull)
  unit            Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  classSession    ClassSession?       @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  createdBy       User?               @relation("ResourceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  sources         ResourceSource[]
  tags            ResourceTag[]
  objectives      ResourceObjective[]
  canvasItems     CanvasExternalItem[]

  @@index([workspaceId, resourceType])
  @@index([workspaceId, sourceType])
  @@index([courseId])
  @@index([classSessionId])
  @@index([hash])
}

model CanvasExternalItem {
  id                 String         @id @default(cuid())
  workspaceId        String?
  courseId           String?
  resourceId         String?
  itemType           CanvasItemType
  canvasCourseId     String?
  canvasModuleId     String?
  canvasAssignmentId String?
  canvasFileId       String?
  title              String
  htmlUrl            String?
  metadataJson       Json?
  lastSyncedAt       DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  workspace          Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  course             Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  resource           Resource?      @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, itemType])
  @@index([courseId])
  @@index([resourceId])
  @@index([canvasCourseId])
  @@index([canvasAssignmentId])
  @@index([canvasFileId])
}

model ResourceSource {
  id                   String     @id @default(cuid())
  resourceId           String
  sourceType           SourceType
  externalId           String?
  externalParentId     String?
  webUrl               String?
  downloadUrl          String?
  localPath            String?
  providerMetadataJson Json?
  lastSyncedAt         DateTime?
  syncStatus           SyncStatus @default(PENDING)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  resource             Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([sourceType, externalId])
  @@index([resourceId])
}

model Tag {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  tagType     TagType       @default(CUSTOM)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  resources   ResourceTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId, tagType])
}

model ResourceTag {
  resourceId String
  tagId      String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
  @@index([tagId])
}

model CurriculumObjective {
  id          String                  @id @default(cuid())
  workspaceId String?
  country     String                  @default("CL")
  source      String                  @default("MINEDUC")
  version     String?
  level       String
  subject     String
  axis        String?
  code        String
  title       String?
  description String
  skills      String?
  attitudes   String?
  sourceUrl   String?
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  workspace   Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  classes     ClassSessionObjective[]
  resources   ResourceObjective[]
  units       CurriculumUnitObjective[]

  @@unique([workspaceId, country, source, level, subject, code])
  @@index([level, subject])
  @@index([axis])
}

model CurriculumUnit {
  id          String                    @id @default(cuid())
  workspaceId String?
  country     String                    @default("CL")
  source      String                    @default("MINEDUC")
  version     String?
  level       String
  subject     String
  code        String
  title       String
  description String?
  orderIndex  Int
  sourceUrl   String?
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  workspace   Workspace?                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  objectives  CurriculumUnitObjective[]

  @@unique([workspaceId, country, source, level, subject, code])
  @@index([level, subject, orderIndex])
}

model CurriculumUnitObjective {
  curriculumUnitId String
  objectiveId      String
  curriculumUnit   CurriculumUnit       @relation(fields: [curriculumUnitId], references: [id], onDelete: Cascade)
  objective        CurriculumObjective  @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@id([curriculumUnitId, objectiveId])
  @@index([objectiveId])
}

model ClassSessionObjective {
  classSessionId String
  objectiveId    String
  classSession   ClassSession        @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  objective      CurriculumObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@id([classSessionId, objectiveId])
  @@index([objectiveId])
}

model ResourceObjective {
  resourceId  String
  objectiveId String
  resource    Resource            @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  objective   CurriculumObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@id([resourceId, objectiveId])
  @@index([objectiveId])
}

model GeneratedItem {
  id             String            @id @default(cuid())
  workspaceId    String
  courseId       String?
  classSessionId String?
  itemType       GeneratedItemType
  promptSnapshot String?
  contentJson    Json
  createdById    String?
  createdAt      DateTime          @default(now())
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  course         Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  classSession   ClassSession?     @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  createdBy      User?             @relation("GeneratedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workspaceId, itemType])
  @@index([courseId])
  @@index([classSessionId])
}
